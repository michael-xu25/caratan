# Copy to .env and fill in. .env is gitignored.
# Load with:  set -a; source .env; set +a

# Anthropic (Claude) — needed for the scenario scorer / Claude agent.
ANTHROPIC_API_KEY=

# Fireworks — GRPO training + hosted inference.
FIREWORKS_API_KEY=
# Deployed base model id (no fireworks: prefix), e.g.
# accounts/<acct>/deployments/<id>. Harness uses fireworks:$FIREWORKS_MODEL.
FIREWORKS_MODEL=
