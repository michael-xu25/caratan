# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Secrets — never commit
.env
.env.local
.secrets/
*.key
.claude/settings.local.json

# Eval output — run transcripts are SHARED BY DEFAULT so every run is visible to
# the team (commit + push and they go out). Only scratch/dev dirs are ignored:
# name a throwaway run dir with a leading underscore to keep it local.
transcripts/_*/

# Generated viewer run-picker manifest (env-specific; rebuilt by view.sh /
# scripts/build_viewer_index.py)
viewer/runs.json

# Office temp/lock files
~$*

# OS / editor
.DS_Store
.idea/
.vscode/

# Large regenerable placement scenarios (rich, with serialized_state). The
# launch-ready reward-kit rows (.trl.jsonl) are committed; regenerate the rich
# file with: python -m goldilocks_eval.placement_env generate ...
data/placement_opening_train.jsonl

# Interactive demo games (temp; separate from recorded transcripts)
demo_games/
