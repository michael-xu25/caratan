# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Secrets — never commit
.env
.env.local
.secrets/
*.key
.claude/settings.local.json

# Eval output — run transcripts are SHARED BY DEFAULT so every run is visible to
# the team (commit + push and they go out). Only scratch/dev dirs are ignored:
# name a throwaway run dir with a leading underscore to keep it local.
transcripts/_*/

# Generated viewer run-picker manifest (env-specific; rebuilt by view.sh /
# scripts/build_viewer_index.py)
viewer/runs.json

# Office temp/lock files
~$*

# OS / editor
.DS_Store
.idea/
.vscode/
